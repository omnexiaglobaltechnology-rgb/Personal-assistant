{
  "expo": {
    "name": "PA",
    "slug": "pa",
    "owner": "omnexia",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#121214"
    },
    "android": {
      "package": "com.agentic.assistant",
      "permissions": [
        "RECORD_AUDIO",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE",
        "SYSTEM_ALERT_WINDOW",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "./plugins/withAndroidAgenticService"
    ],
    "extra": {
      "eas": {
        "projectId": "fbe7238d-caa0-4102-be09-ac1016974ab2"
      }
    }
  }
}
